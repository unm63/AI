from llama_index.core import VectorStoreIndex, SimpleDirectoryReader, Settings
from llama_index.embeddings.huggingface import HuggingFaceEmbedding
from llama_index.llms.ollama import Ollama

# 1. Configure the pipeline entirely locally (No keys required)
Settings.embed_model = HuggingFaceEmbedding(model_name="BAAI/bge-small-en-v1.5")
Settings.llm = Ollama(model="llama3", request_timeout=60.0)

# 2. Run the ingestion and indexing pipeline
print("Ingesting local data documents...")
documents = SimpleDirectoryReader("data").load_data()

print("Building vector indexing...")
index = VectorStoreIndex.from_documents(documents)

# 3. Create the query engine layer
query_engine = index.as_query_engine()

# 4. Ask your question and print the real text output!
print("\nQuerying the local LLM...")
response = query_engine.query("What are the details about the summer tutoring program?")

print("\n--- AI Response ---")
print(response)
